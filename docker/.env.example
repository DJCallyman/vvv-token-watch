# Environment variables for Docker Compose
# Copy this file to .env and fill in your values

# Required: Venice AI Admin API Key
VENICE_ADMIN_KEY=your_venice_admin_key_here

# REQUIRED: Shared password protecting the web UI and API. The app refuses
# to start without this set (unless ALLOW_INSECURE_NO_AUTH=true).
# Generate one with: openssl rand -hex 24
APP_PASSWORD=

# Explicit opt-in to run without authentication. NOT recommended.
ALLOW_INSECURE_NO_AUTH=false

# Optional: CoinGecko API Key for higher rate limits
COINGECKO_API_KEY=

# Database configuration. Use a strong, unique password — do not keep the
# vvvwatch/vvvwatch default below in any real deployment.
DATABASE_URL=postgresql://vvvwatch:CHANGE_ME@postgres:5432/vvvwatch
DB_USER=vvvwatch
DB_PASSWORD=CHANGE_ME

# Optional: Token holdings for portfolio calculation
COINGECKO_HOLDING_AMOUNT=2750
DIEM_HOLDING_AMOUNT=0

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO