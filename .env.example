# ============================================================================
# VVV Token Watch - Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your actual values
# Run: cp .env.example .env (macOS/Linux)
# ============================================================================

# ----------------------------------------------------------------------------
# VENICE AI API KEYS - Get from: https://venice.ai/settings/api
# ----------------------------------------------------------------------------

# REQUIRED: Venice Admin API Key (for billing/usage monitoring)
# IMPORTANT: Must be an "Admin" key type, NOT "Inference Only"
# Regular inference keys will return 401 Unauthorized on /billing/usage endpoint
VENICE_ADMIN_KEY=

# OPTIONAL: Venice Inference API Key
# Used for public endpoints like /models to avoid exposing the admin key
VENICE_API_KEY=

# ----------------------------------------------------------------------------
# VENICE API PAGINATION SETTINGS (Advanced)
# ----------------------------------------------------------------------------

# Number of results to fetch per API request page
# Default: 500 (max supported by Venice API)
API_PAGE_SIZE=500

# Maximum number of pages to fetch before stopping
# Default: 20 (prevents runaway queries)
API_MAX_PAGES=20

# ----------------------------------------------------------------------------
# VENICE BILLING DEFAULTS
# ----------------------------------------------------------------------------

# Default daily DIEM spending limit for API keys (fallback value)
# Used when API key doesn't have explicit limits configured
DEFAULT_DAILY_DIEM_LIMIT=100.0

# Default daily USD spending limit for API keys (fallback value)
DEFAULT_DAILY_USD_LIMIT=25.0

# Fallback DIEM to USD exchange rate (used when live rates unavailable)
# Default: 0.72 (1 DIEM = $0.72 USD)
DEFAULT_EXCHANGE_RATE=0.72

# ----------------------------------------------------------------------------
# COINGECKO CONFIGURATION - Venice Token (VVV)
# ----------------------------------------------------------------------------

# OPTIONAL: CoinGecko Pro API Key (for higher rate limits)
# Get your free API key from: https://www.coingecko.com/en/api/pricing
# Without this key, you'll be limited to ~30 calls/minute (free tier)
# With a free Pro key, you get ~100 calls/minute
# Leave empty to use the free tier
COINGECKO_API_KEY=

# CoinGecko token identifier for Venice token
# Default: venice-token (do not change unless tracking different token)
COINGECKO_TOKEN_ID=venice-token

# Currencies to fetch prices for (comma-separated, no spaces)
# Default: usd,aud
COINGECKO_CURRENCIES=usd,aud

# Your VVV token holdings (for portfolio value calculation)
# Default: 2750 (update this to your actual holdings)
COINGECKO_HOLDING_AMOUNT=2750

# Price update interval in milliseconds
# Default: 60000 (1 minute)
# CoinGecko free tier allows ~30 calls/minute
COINGECKO_REFRESH_INTERVAL_MS=60000

# Initial delay before first price fetch (milliseconds)
# Default: 500ms (prevents API spam on startup)
COINGECKO_INITIAL_DELAY_MS=500

# ----------------------------------------------------------------------------
# COINGECKO CONFIGURATION - DIEM Token
# ----------------------------------------------------------------------------

# CoinGecko token identifier for DIEM token
# Default: diem
DIEM_TOKEN_ID=diem

# Your DIEM token holdings (for portfolio value calculation)
# Default: 0
DIEM_HOLDING_AMOUNT=0

# ----------------------------------------------------------------------------
# APPLICATION SETTINGS
# ----------------------------------------------------------------------------

# Backend log level: INFO or DEBUG
LOG_LEVEL=INFO

# Set to true to echo all SQL statements (can log sensitive data)
SQL_ECHO=false

# Local data directory
DATA_DIR=./data

# Local log file path
LOG_FILE_PATH=./data/logs/app.log
